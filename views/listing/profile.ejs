<!DOCTYPE html>
<html>
<head>
  <title>Your Profile</title>
  <link rel="stylesheet" href="/css/profile.css">
</head>
<body>



<div class="container" style="margin-top:100px; max-width:700px; margin-left:auto; margin-right:auto;">
  
  <h2>Profile Details</h2>

  <p><strong>Email:</strong> <%= user.email %></p>

  <form action="/profile" method="POST">

    <div style="margin-bottom:15px;">
      <label>Name</label><br>
      <input type="text" name="name" value="<%= user.name %>" required style="width:100%; padding:8px;">
    </div>

    <div style="margin-bottom:15px;">
      <label>Age</label><br>
      <input type="number" name="age" value="<%= user.age || '' %>" required style="width:100%; padding:8px;">
    </div>

    <div style="margin-bottom:15px;">
      <label>Location</label><br>
      <input type="text" name="location" value="<%= user.location %>" required style="width:100%; padding:8px;">
    </div>

    <div style="margin-bottom:15px;">
      <label>Full Address</label><br>
      <textarea name="address" required style="width:100%; padding:8px;"><%= user.address %></textarea>
    </div>

    <div style="margin-bottom:15px;">
      <label>Taluka (TQ)</label><br>
      <input type="text" name="taluka" value="<%= user.taluka %>" required style="width:100%; padding:8px;">
    </div>

    <div style="margin-bottom:15px;">
      <label>District</label><br>
      <input type="text" name="district" value="<%= user.district %>" required style="width:100%; padding:8px;">
    </div>

    <button type="submit" style="padding:10px 20px; background:green; color:white; border:none;">
      Save Details
    </button>

  </form>

</div>

</body>
</html>