<!DOCTYPE html>
<html lang="en">
<head>

<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>KrishiSphere | Smart Agriculture Portal</title>

<link rel="stylesheet" href="/css/home.css">

<!-- Google Font -->
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">

<!-- Icons -->
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">

</head>

<body>

<!-- ================= NAVBAR ================= -->
<nav class="navbar">

<div class="logo">
Krishi<span>Sphere</span>
</div>

<!-- Mobile Menu -->
<div class="menu-toggle">☰</div>

<ul class="nav-links">

<li><a href="/home"><i class="fa-solid fa-house"></i> Home</a></li>
<li><a href="/weather"><i class="fa-solid fa-cloud-sun"></i> Weather</a></li>
<li><a href="/crop"><i class="fa-solid fa-seedling"></i> Crop</a></li>
<li><a href="/products"><i class="fa-solid fa-store"></i> Products</a></li>
<li><a href="/articles"><i class="fa-solid fa-newspaper"></i> Articles</a></li>

<% if (!user) { %>

<li><a href="/login" class="nav-btn">Login</a></li>

<% } else { %>

<li class="profile-menu">

<div class="profile-icon">👤</div>

<div class="dropdown">

<p>
<strong>
<a href="/profile" style="text-decoration:none;color:inherit;">
<%= user.email %>
</a>
</strong>
</p>

<a href="/logout">Logout</a>

</div>

</li>

<% } %>

</ul>
</nav>

<!-- ================= HERO ================= -->
<section class="hero">

<div class="hero-glass">

<h1>Smart Crop Suggestions for Your Farm</h1>

<p>
Get real-time weather updates, discover the best crops for your soil,
and improve your farming profit with smart agriculture insights.
</p>

<div class="hero-btns">

<a href="/crop" class="btn-primary">
🌱 Get Crop Suggestion
</a>

<a href="/products" class="btn-secondary">
🛒 Browse Farm Products
</a>

</div>

</div>

</section>

<!-- ================= FEATURES ================= -->
<section class="features">

<h2 class="section-title">What KrishiSphere Helps You Do</h2>

<div class="feature-container">

<a href="/weather" class="card-link">
<div class="card weather-card">
<div class="card-icon"><i class="fa-solid fa-cloud-sun"></i></div>
<h3>Live Weather Updates</h3>
<p>Plan irrigation and farming using accurate forecasts.</p>
<span class="card-btn">Open Forecast →</span>
</div>
</a>

<a href="/crop" class="card-link">
<div class="card crop-card">
<div class="card-icon"><i class="fa-solid fa-seedling"></i></div>
<h3>Crop Recommendations</h3>
<p>Get best crops based on soil data and location.</p>
<span class="card-btn">Analyze Soil →</span>
</div>
</a>

<a href="/products" class="card-link">
<div class="card product-card">
<div class="card-icon"><i class="fa-solid fa-store"></i></div>
<h3>Farm Products</h3>
<p>Buy seeds, fertilizers and modern tools.</p>
<span class="card-btn">Browse Products →</span>
</div>
</a>

</div>

</section>

<!-- ================= ARTICLES ================= -->
<section class="articles">

<h2 class="section-title">Latest Agriculture Articles</h2>

<div class="articles-container">

<% if (articles && articles.length > 0) { %>

<% articles.forEach(article => { %>

<a href="/articles/<%= article._id %>" class="article-card-link">

<div class="article-card">

<h3><%= article.title %></h3>

<p>
<%= article.summary || article.content.substring(0,120) %>...
</p>

<span class="card-btn">Read Article →</span>

</div>

</a>

<% }) %>

<% } else { %>

<p style="text-align:center">No articles available yet.</p>

<% } %>

</div>

<div style="text-align:center;margin-top:30px;">
<a href="/articles" class="btn-secondary">View All Articles</a>
</div>

</section>

<!-- ================= HOW IT WORKS ================= -->
<section class="how-it-works">

<h2 class="section-title">How It Works</h2>

<div class="steps">

<div class="step">
<div class="step-icon">🌱</div>
<h3>Enter Soil Details</h3>
<p>Provide soil pH and conditions of your land.</p>
</div>

<div class="step">
<div class="step-icon">📍</div>
<h3>Select District</h3>
<p>Choose your district for accurate insights.</p>
</div>

<div class="step">
<div class="step-icon">🌾</div>
<h3>Get Best Crops</h3>
<p>Receive high-yield crop suggestions.</p>
</div>

</div>

</section>

<!-- ================= CTA ================= -->
<section class="cta">

<h2>Find the Best Crop for Your Soil Today</h2>

<p>Start analyzing your soil and increase your farm profit.</p>

<a href="/crop" class="btn-primary">Start Crop Analysis</a>

</section>

<!-- ================= FOOTER ================= -->
<footer class="footer">

<div class="footer-container">

<div class="footer-logo">
Krishi<span>Sphere</span>
<p>Helping farmers make smarter crop decisions.</p>
</div>

<div class="footer-links">
<a href="/home">Home</a>
<a href="/crop">Crop Suggestion</a>
<a href="/weather">Weather</a>
<a href="/products">Products</a>
<a href="/articles">Articles</a>
</div>

</div>

<p class="copyright">
© 2026 KrishiSphere. All rights reserved.
</p>

</footer>

<!-- ================= JS ================= -->
<script>
const toggle = document.querySelector('.menu-toggle');
const nav = document.querySelector('.nav-links');

toggle.addEventListener('click', () => {
  nav.classList.toggle('active');
});
</script>

</body>
</html>