<!DOCTYPE html>
<html>
<head>
    <title><%= product.name %></title>
    <style>
        body {
            font-family: Arial;
            background: #f4f6f8;
            padding: 40px;
        }

        .container {
            display: flex;
            gap: 50px;
            background: white;
            padding: 30px;
            border-radius: 15px;
            max-width: 1100px;
            margin: auto;
        }

        .left img {
            width: 500px;
            height: 450px;
            object-fit: cover;
            border-radius: 15px;
        }

        .right {
            flex: 1;
        }

        .price {
            font-size: 24px;
            color: #e67e22;
            font-weight: bold;
            margin: 10px 0;
        }

        .section {
            margin-top: 15px;
        }

        h3 {
            margin-bottom: 5px;
        }

        button {
            margin-top: 25px;
            padding: 12px 25px;
            background: green;
            color: white;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            font-size: 16px;
        }

        button:hover {
            background: darkgreen;
        }
    </style>
</head>
<body>

<div class="container">

    <!-- LEFT SIDE IMAGE -->
    <div class="left">
        <img src="<%= product.image %>" alt="<%= product.name %>">
    </div>

    <!-- RIGHT SIDE DETAILS -->
    <div class="right">

        <h1><%= product.name %></h1>

        <div class="price">
            ₹ <%= product.price %>
        </div>

        <div class="section">
            <h3>Category</h3>
            <p><%= product.category %></p>
        </div>

        <div class="section">
            <h3>Suitable Crops</h3>
            <p><%= product.suitableCrops.join(", ") %></p>
        </div>

        <div class="section">
            <h3>Soil pH Range</h3>
            <p><%= product.minPH %> - <%= product.maxPH %></p>
        </div>

        <div class="section">
            <h3>Nitrogen Support</h3>
            <p><%= product.nitrogenSupport %></p>
        </div>

        <div class="section">
            <h3>Description</h3>
            <p><%= product.description %></p>
        </div>

        <!-- BUY BUTTON (WORKING) -->
        <div class="section">
            <form action="/buy/<%= product._id %>" method="POST">
                <button type="submit">Buy Now</button>
            </form>
        </div>

    </div>

</div>

</body>
</html>