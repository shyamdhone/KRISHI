<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ProductSphere | Agriculture Marketplace</title>
    <link rel="stylesheet" href="/css/products.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">
</head>
<body>

<div class="container">
    <header class="header">
        <h1>Product<span>Sphere</span></h1>
        <p>Premium fertilizers & seeds for higher yields</p>
    </header>

    <% if (products && products.length > 0) { %>
        <div class="product-grid">
            <% products.forEach(product => { %>
                <div class="product-card">
                    <a href="/products/<%= product._id %>" class="image-wrapper">
                        <% if(product.image){ %>
                            <img src="<%= product.image %>" alt="<%= product.name %>">
                        <% } else { %>
                            <img src="https://images.unsplash.com/photo-1586771107445-d3ca888129ff?auto=format&fit=crop&q=80&w=400" alt="Placeholder">
                        <% } %>
                        <div class="price-tag">₹<%= product.price %></div>
                    </a>

                    <div class="product-content">
                        <span class="category-pill">Agriculture</span>
                        <h2><%= product.name || "Unnamed Product" %></h2>
                        
                        <p>
                            <%= product.description && product.description.length > 70 
                                ? product.description.substring(0, 70) + "..." 
                                : product.description || "No description available." %>
                        </p>

                        <div class="card-footer">
                            <a href="/products/<%= product._id %>" class="btn-view">Details</a>
                            <form action="/buy/<%= product._id %>" method="POST" style="display:inline;">
                                <button type="submit" class="btn-buy">Buy Now</button>
                            </form>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>
    <% } else { %>
        <div class="empty-state">
            <p>No products available at the moment.</p>
            <a href="/home" class="btn-view">Back to Home</a>
        </div>
    <% } %>
</div>

</body>
</html>